# ─────────────────────────────────────────────────────────────
#  UCAS — University Course Allocation System
#  Environment Variables Template
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL) ───────────────────────────────────
# Local development (matches docker-compose.dev.yml):
DATABASE_URL="postgresql://ucas_user:ucas_pass@localhost:5432/ucas?schema=timetable"

# VPS production (Dokploy internal service URL):
# DATABASE_URL="postgresql://ucas_user:STRONG_PASS@postgres:5432/ucas?schema=timetable"

# ─── NextAuth ────────────────────────────────────────────────
# Must be the full URL where your app is served
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING"

# ─── Redis (BullMQ background jobs) ─────────────────────────
# Local:
REDIS_URL="redis://localhost:6379"

# VPS production:
# REDIS_URL="redis://redis:6379"

# ─── Email (Nodemailer SMTP) ─────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="ucas@pu.edu.pk"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="UCAS System <ucas@pu.edu.pk>"

# ─── University Identity ─────────────────────────────────────
NEXT_PUBLIC_UNIVERSITY_NAME="University of Punjab"
NEXT_PUBLIC_UNIVERSITY_SHORT="PU"
NEXT_PUBLIC_UNIVERSITY_LOCATION="Lahore, Pakistan"
NEXT_PUBLIC_APP_NAME="UCAS"

# ─── Application ─────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Friday Prayer Break (24h format, configurable) ──────────
FRIDAY_PRAYER_START="12:30"
FRIDAY_PRAYER_END="14:00"

# ─── Schedule Constraints ────────────────────────────────────
# Earliest class start (24h)
BS_EARLIEST_START="08:00"
# Latest class end for BS
BS_LATEST_END="18:00"
# Latest class end for MS/PhD
MS_LATEST_END="21:00"
# Computer lab window
LAB_EARLIEST_START="16:00"
LAB_LATEST_END="19:00"
